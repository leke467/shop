# ==========================================================================
# Example environment file. Copy to `.env` and fill in real values.
#   cp .env.example .env
# The real `.env` is gitignored and must never be committed.
# Choose settings via DJANGO_SETTINGS_MODULE (defaults to dev in manage.py):
#   DJANGO_SETTINGS_MODULE=ecommerce.settings.dev   (local)
#   DJANGO_SETTINGS_MODULE=ecommerce.settings.prod  (production)
# ==========================================================================

# --- Core ---
DJANGO_SECRET_KEY=change-me-generate-a-long-random-value
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (local dev uses MSSQL) ---
# DB_TYPE: sqlite | postgres | mssql
DB_TYPE=mssql
DB_NAME=shopdb
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost\INSTANCE
DB_PORT=
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=yes

# --- Production database (PostgreSQL) example ---
# DB_TYPE=postgres
# DB_NAME=marketplace
# DB_USER=marketplace
# DB_PASSWORD=strong-password
# DB_HOST=db
# DB_PORT=5432

# --- JWT / auth cookies ---
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
AUTH_COOKIE_SECURE=False        # True in production (HTTPS only)
AUTH_COOKIE_SAMESITE=Lax
# AUTH_COOKIE_DOMAIN=.example.com

# --- CORS / CSRF (frontend origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Redis / Celery (production) ---
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=django-db
# Run tasks inline without a worker during local dev:
CELERY_TASK_ALWAYS_EAGER=True

# --- Throttling (requests / period) ---
THROTTLE_ANON=60/min
THROTTLE_USER=240/min
THROTTLE_AUTH=10/min
THROTTLE_CHECKOUT=20/min

# --- Payments ---
PAYMENTS_DEFAULT_CURRENCY=USD
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# --- Email (production SMTP) ---
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=no-reply@example.com

# --- Static/media offload (production, S3-compatible) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=

# --- Error monitoring ---
# SENTRY_DSN=
